# frozen_string_literal: true

require_relative "../config/environment"

# EventIngestionWorker
#
# Consome o stream Redis `stratify:events` e faz o broadcast
# em tempo real para o Frontend via ActionCable.
class EventIngestionWorker
  EVENT_STREAM = "stratify:events"
  GROUP_NAME      = "core-backend-event-reflector"
  CONSUMER_NAME   = "event-reflector-#{Process.pid}"
  BATCH_SIZE      = 20
  BLOCK_MS        = 2_000

  def initialize
    @redis = Redis.new(url: ENV.fetch("REDIS_URL", "redis://localhost:6379/0"))
    setup_consumer_group
  end

  def run!
    Rails.logger.info("[EventIngestionWorker] Reflecting #{EVENT_STREAM} to WebSockets...")

    loop do
      results = @redis.xreadgroup(
        GROUP_NAME, CONSUMER_NAME,
        EVENT_STREAM, ">",
        count: BATCH_SIZE,
        block: BLOCK_MS
      )

      next if results.nil? || results.empty?

      results.each do |_stream, messages|
        messages.each do |msg_id, fields|
          begin
            event = JSON.parse(fields["data"])
            # Broadcast para o canal de eventos reais
            ActionCable.server.broadcast("game_events_global", event)
            @redis.xack(EVENT_STREAM, GROUP_NAME, msg_id)
          rescue => e
            Rails.logger.error("[EventIngestionWorker] Error: #{e.message}")
            @redis.xack(EVENT_STREAM, GROUP_NAME, msg_id)
          end
        end
      end
    end
  rescue Interrupt
    Rails.logger.info("[EventIngestionWorker] Stopped.")
  end

  private

  def setup_consumer_group
    @redis.xgroup(:create, EVENT_STREAM, GROUP_NAME, "$", mkstream: true)
  rescue Redis::CommandError => e
    raise unless e.message.include?("BUSYGROUP")
  end
end

EventIngestionWorker.new.run!
